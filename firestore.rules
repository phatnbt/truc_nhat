rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      // Bản demo dùng Anonymous Authentication.
      // Với production, nên thay bằng kiểm tra thành viên phòng theo UID/custom claims.
      allow read, write: if request.auth != null && roomId == "P708";
    }
  }
}
